<script>
let currentRunning = null;

function switchTab(tabId) {
    document.querySelectorAll('.tab-content').forEach(tab => tab.classList.remove('active'));
    document.querySelectorAll('.tab').forEach(btn => btn.classList.remove('active'));
    document.getElementById(tabId).classList.add('active');
    event.target.classList.add('active');
}

async function runTestClass(system, testClass) {
    if (currentRunning) { alert('Test already running'); return; }

    currentRunning = testClass;
    updateStatus(testClass, 'running', 'Running...');
    document.getElementById('output').innerHTML = `Start ${testClass}...<div class="loading"></div>`;

    try {
        const response = await fetch('/run-tests/', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ system: system, test_class: testClass })
        });
        const result = await response.json();

        if (result.success) {
            updateStatus(testClass, 'passed', `Passed (${result.tests_run} С‚РµСЃС‚РѕРІ)`);
            document.getElementById('output').innerHTML = `<span class="success">Passed</span><br>Succeded: ${result.tests_run}<br>Errors: ${result.errors}<br>fallings: ${result.failures}`;
        } else {
            updateStatus(testClass, 'failed', 'Failed');
            document.getElementById('output').innerHTML = `<span class="error">Failed</span><br>${result.error || ''}`;
        }
    } catch (error) {
        updateStatus(testClass, 'failed', 'Error');
        document.getElementById('output').innerHTML = `<span class="error">Error: ${error}</span>`;
    } finally { currentRunning = null; }
}

async function runSystemTests(system) {
    if (currentRunning) { alert('Teat already running'); return; }
    currentRunning = system;
    document.getElementById('output').innerHTML = `Starting system ${system}...<div class="loading"></div>`;

    try {
        const response = await fetch('/run-tests/', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ system: system })
        });
        const result = await response.json();
        document.getElementById('output').innerHTML = `<pre>${JSON.stringify(result, null, 2)}</pre>`;
    } catch (error) {
        document.getElementById('output').innerHTML = `<span class="error">Error: ${error}</span>`;
    } finally { currentRunning = null; }
}

async function runAllSystems() {
    if (currentRunning) { alert('РўРµСЃС‚ СѓР¶Рµ РІС‹РїРѕР»РЅСЏРµС‚СЃСЏ'); return; }
    currentRunning = 'all';
    document.getElementById('output').innerHTML = `Starting all syst...<div class="loading"></div>`;

    try {
        const response = await fetch('/run-tests/', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ system: 'all' })
        });
        const result = await response.json();
        document.getElementById('output').innerHTML = `<pre>${JSON.stringify(result, null, 2)}</pre>`;
    } catch (error) {
        document.getElementById('output').innerHTML = `<span class="error">Error: ${error}</span>`;
    } finally { currentRunning = null; }
}

function updateStatus(testId, status, message) {
    const el = document.getElementById(`status-${testId}`);
    if (el) { el.className = `status ${status}`; el.textContent = message; }
}
</script>
</body>
