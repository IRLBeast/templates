<script>
let currentRunning = null;

function switchTab(tabId) {
    document.querySelectorAll('.tab-content').forEach(tab => tab.classList.remove('active'));
    document.querySelectorAll('.tab').forEach(btn => btn.classList.remove('active'));
    document.getElementById(tabId).classList.add('active');
    event.target.classList.add('active');
}

async function runTestClass(system, testClass) {
    if (currentRunning) { alert('РўРµСЃС‚ СѓР¶Рµ РІС‹РїРѕР»РЅСЏРµС‚СЃСЏ'); return; }

    currentRunning = testClass;
    updateStatus(testClass, 'running', 'Р’С‹РїРѕР»РЅСЏРµС‚СЃСЏ...');
    document.getElementById('output').innerHTML = `Р—Р°РїСѓСЃРє ${testClass}...<div class="loading"></div>`;

    try {
        const response = await fetch('/run-tests/', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ system: system, test_class: testClass })
        });
        const result = await response.json();

        if (result.success) {
            updateStatus(testClass, 'passed', `РџСЂРѕР№РґРµРЅ (${result.tests_run} С‚РµСЃС‚РѕРІ)`);
            document.getElementById('output').innerHTML = `<span class="success">Test passed</span><br>Р’С‹РїРѕР»РЅРµРЅРѕ: ${result.tests_run}<br>РћС€РёР±РѕРє: ${result.errors}<br>РџР°РґРµРЅРёР№: ${result.failures}`;
        } else {
            updateStatus(testClass, 'failed', 'РџСЂРѕРІР°Р»РµРЅ');
            document.getElementById('output').innerHTML = `<span class="error">Test failed</span><br>${result.error || ''}`;
        }
    } catch (error) {
        updateStatus(testClass, 'failed', 'Error');
        document.getElementById('output').innerHTML = `<span class="error">Error: ${error}</span>`;
    } finally { currentRunning = null; }
}

async function runSystemTests(system) {
    if (currentRunning) { alert('Test already in progress'); return; }
    currentRunning = system;
    document.getElementById('output').innerHTML = `System start ${system}...<div class="loading"></div>`;

    try {
        const response = await fetch('/run-tests/', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ system: system })
        });
        const result = await response.json();
        document.getElementById('output').innerHTML = `<pre>${JSON.stringify(result, null, 2)}</pre>`;
    } catch (error) {
        document.getElementById('output').innerHTML = `<span class="error">РћС€РёР±РєР°: ${error}</span>`;
    } finally { currentRunning = null; }
}

async function runAllSystems() {
    if (currentRunning) { alert('Test already in progress'); return; }
    currentRunning = 'all';
    document.getElementById('output').innerHTML = `Running all systems...<div class="loading"></div>`;

    try {
        const response = await fetch('/run-tests/', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ system: 'all' })
        });
        const result = await response.json();
        document.getElementById('output').innerHTML = `<pre>${JSON.stringify(result, null, 2)}</pre>`;
    } catch (error) {
        document.getElementById('output').innerHTML = `<span class="error">Error: ${error}</span>`;
    } finally { currentRunning = null; }
}

function updateStatus(testId, status, message) {
    const el = document.getElementById(`status-${testId}`);
    if (el) { el.className = `status ${status}`; el.textContent = message; }
}
</script>
