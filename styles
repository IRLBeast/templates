from selenium.webdriver.common.by import By
from selenium.webdriver.support.ui import WebDriverWait
from selenium.webdriver.support import expected_conditions as EC
import time
from driver import chrome_driver


def test_credit_register_basic(chrome_driver):
    wait = WebDriverWait(chrome_driver, 15)

    chrome_driver.get("http://q-web-open/")
    time.sleep(5)
    
    assert "kred" in chrome_driver.title
    print(f"title is: {chrome_driver.title}")
    
    personal_link = chrome_driver.find_element(By.XPATH, "//a[contains(text(), 'Cabinet') or @href='/Authenticate']")
    personal_link.click()
    time.sleep(3)

    assert "/Authenticate" in chrome_driver.current_url
    print(f"went: {chrome_driver.current_url}")

    personal_link = chrome_driver.find_element(By.XPATH, "//a[contains(text(), 'Cabinet') or @href='/AuthenticateLegal']")
    personal_link.click()
    time.sleep(3)
    
    assert "/AuthenticateLegal" in chrome_driver.current_url
    print(f"went: {chrome_driver.current_url}")

    try:
        assert "USBToken" in chrome_driver.page_source
        print("USBToken")
    except AssertionError:
        print("USBToken' found")
        raise

    print("\nUSBToken")
    
    try:
        usb_token_link = wait.until(
            EC.element_to_be_clickable((By.ID, "avest-legal-usb-url"))
        )
        print(f"URL: {usb_token_link.get_attribute('href')}")
        
        usb_token_link.click()
        print("USBToken")
        
        time.sleep(5)

        current_url = chrome_driver.current_url
        print(f"current URL: {current_url}")
        
        assert current_url != "http://q-web-open/AuthenticateLegal", "not changed"
        
        if "oauth/authorize" in current_url or "avest" in current_url.lower():
            print("succ OAuth")
        else:
            print(f"went: {current_url}")
            
    except Exception as e:
        print(f"err: {e}")

    try:
        assert "Test" in chrome_driver.page_source
        print("text")
    except AssertionError:
        print("text")
        raise

    cert_input = chrome_driver.find_element(By.ID, "serialnum")
    cert_input.send_keys("20084965288178895105415972429")
    certificate_button = wait.until(EC.element_to_be_clickable((By.XPATH, "//input[@type='submit']")))
    certificate_button.click()
    time.sleep(3)

    submit_button = chrome_driver.find_element(By.CSS_SELECTOR, "input[type='submit']")
    submit_button.click()
    time.sleep(3)

    try:
        assert "Get report" in chrome_driver.page_source
        print("text")
    except AssertionError:
        print("text")
        raise

    logout_link = chrome_driver.find_element(By.XPATH, "//a[contains(text(), 'Р’С‹С…РѕРґ') or @href='/AuthenticateLegal/SignOut']")
    logout_link.click()
    time.sleep(3)

    try:
        assert "hist" in chrome_driver.page_source
        print("text 'hist' found")
    except AssertionError:
        print("Text' not found")
        raise

    
    print("Success!")


