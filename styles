def test_runner_dashboard(request):
    """Дашборд для запуска тестов"""
    return render(request, 'main/mainpage.html')


@csrf_exempt
@require_http_methods(["POST"])
def run_tests_api(request):
    """API для запуска тестов"""
    try:
        data = json.loads(request.body.decode('utf-8'))
        test_name = data.get('test_name', '')
        
        print(f"Запуск теста: {test_name}")
        
        if test_name == 'CreditRegisterTests':
            result = run_test_class(CreditRegisterTests)
        elif test_name == 'CreditRegisterAuthTests':
            result = run_test_class(CreditRegisterAuthTests)
        else:
            return JsonResponse({'success': False, 'error': f'Неизвестный тест: {test_name}'}, status=400)
        
        return JsonResponse(result)
        
    except Exception as e:
        return JsonResponse({
            'success': False,
            'error': str(e),
            'traceback': traceback.format_exc()
        }, status=500)


def run_test_class(test_class):
    """Запуск тестового класса"""
    try:
        # Создаем загрузчик тестов
        loader = unittest.TestLoader()
        
        # Загружаем все тесты из класса
        suite = loader.loadTestsFromTestCase(test_class)
        
        # Захватываем вывод
        stream = io.StringIO()
        runner = unittest.TextTestRunner(stream=stream, verbosity=2)
        
        # Запускаем тесты
        result = runner.run(suite)
        
        # Получаем вывод
        output = stream.getvalue()
        
        return {
            'success': result.wasSuccessful(),
            'tests_run': result.testsRun,
            'failures': len(result.failures),
            'errors': len(result.errors),
            'output': output,
            'details': {
                'failures': [(str(f[0]), str(f[1])) for f in result.failures],
                'errors': [(str(e[0]), str(e[1])) for e in result.errors]
            }
        }
        
    except Exception as e:
        return {
            'success': False,
            'error': str(e),
            'traceback': traceback.format_exc()
        }


