def test_runner_dashboard(request):
    """Дашборд для запуска тестов"""
    return render(request, 'main/mainpage.html')


@csrf_exempt
@require_http_methods(["POST"])
def run_tests_api(request):
    """API для запуска тестов"""
    try:
        data = json.loads(request.body.decode('utf-8'))
        system = data.get('system', '')
        test_class_name = data.get('test_class', '')
        
        print(f"Запуск: система={system}, класс={test_class_name}")
        
        if system == 'aiskr':
            if test_class_name == 'CreditRegisterTests':
                result = run_test_class(CreditRegisterTests)
            elif test_class_name == 'CreditRegisterAuthTests':
                result = run_test_class(CreditRegisterAuthTests)
            else:
                # Запускаем все тесты AISKR
                result = run_all_aiskr_tests()
        
        elif system == 'smpstat':
            # Когда добавишь тесты SMPstat
            result = {'success': False, 'error': 'Тесты SMPstat в разработке'}
        
        else:
            return JsonResponse({'success': False, 'error': 'Неизвестная система'}, status=400)
        
        return JsonResponse(result)
        
    except Exception as e:
        return JsonResponse({
            'success': False,
            'error': str(e),
            'traceback': traceback.format_exc()
        }, status=500)


def run_test_class(test_class):
    """
    Запуск конкретного тестового класса
    test_class - это класс тестов (например, CreditRegisterTests)
    """
    try:
        # Создаем загрузчик тестов
        loader = unittest.TestLoader()
        
        # Загружаем все тесты из класса
        suite = loader.loadTestsFromTestCase(test_class)
        
        # Захватываем вывод
        stream = io.StringIO()
        runner = unittest.TextTestRunner(stream=stream, verbosity=2)
        
        # Запускаем тесты
        result = runner.run(suite)
        
        # Получаем вывод
        output = stream.getvalue()
        
        # Формируем отчет
        return {
            'success': result.wasSuccessful(),
            'tests_run': result.testsRun,
            'failures': len(result.failures),
            'errors': len(result.errors),
            'output': output,
            'details': {
                'failures': [(str(f[0]), str(f[1])) for f in result.failures],
                'errors': [(str(e[0]), str(e[1])) for e in result.errors]
            }
        }
        
    except Exception as e:
        return {
            'success': False,
            'error': str(e),
            'traceback': traceback.format_exc()
        }


def run_all_aiskr_tests():
    """Запуск всех тестов AISKR"""
    results = {}
    all_success = True
    
    # Список всех тестовых классов для AISKR
    test_classes = [
        ('CreditRegisterTests', CreditRegisterTests),
        ('CreditRegisterAuthTests', CreditRegisterAuthTests),
    ]
    
    for class_name, test_class in test_classes:
        print(f"\n=== Запуск {class_name} ===")
        result = run_test_class(test_class)
        results[class_name] = result
        if not result.get('success', False):
            all_success = False
    
    # Формируем общий вывод
    output = "="*50 + "\n"
    output += "РЕЗУЛЬТАТЫ ВСЕХ ТЕСТОВ AISKR\n"
    output += "="*50 + "\n"
    
    for class_name, result in results.items():
        status = "✅ ПРОЙДЕН" if result.get('success') else "❌ ПРОВАЛЕН"
        output += f"\n{class_name}: {status}\n"
        output += f"  Тестов выполнено: {result.get('tests_run', 0)}\n"
        output += f"  Ошибок: {result.get('errors', 0)}\n"
        output += f"  Падений: {result.get('failures', 0)}\n"
    
    return {
        'success': all_success,
        'results': results,
        'output': output
    }


